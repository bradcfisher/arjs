    "8": {
        "name": "(8) LockedDoor",
        "description": "A locked door that requires a key to unlock it. When a locked door is unlocked, that status is saved with the character.",
        "texture": "../../images/door.png",
        "transparent": false,
        "collision": true,
        "on": {
            "collision": [
                {
                    "action": "core:checkLockedDoorCollision",
                    "parameters": {
                        "on": {
                            "identified": [
                                {
                                    "action": "core:playSound",
                                    "parameters": {
                                        "source": "../../sounds/successfulIdentification.wav"
                                    }
                                },
                                {
                                    "action": "core:patchDoor",
                                    "parameters": {
                                        "wallStyle": "8-visible"
                                    }
                                }
                            ],
                            "key": [],
                            "force": [],
                            "disenchant": [],
                            "success": [
                                {
                                    "action": "core:patchDoor",
                                    "parameters": {
                                        "wallStyle": "3"
                                    }
                                }
                            ]
                        }
                    }
                }
            ]
        }
    },
